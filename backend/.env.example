# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Security / encryption
# FORGE_ENCRYPTION_KEY — REQUIRED in any non-local deployment. Encrypts provider
# API keys at rest (Fernet). If unset, encrypt_secret() passes values through and
# keys are stored PLAINTEXT despite the api_key_encrypted column name.
FORGE_ENCRYPTION_KEY=
# FORGE_JWT_SECRET — signing secret for the local (SQLite) auth backend only.
# FORGE_JWT_SECRET=
# FORGE_DB_BACKEND — "supabase" (default) or "sqlite" for local single-user mode.
# FORGE_DB_BACKEND=supabase

# Computer-use safety (optional; sensible secure defaults recommended)
# CU_REQUIRE_APPROVAL=true        # require human approval before each CU action
# CU_REDACT_SCREENSHOTS=true      # redact captured screenshots
# CU_BLOCKED_APPS=, CU_BLOCKED_COMMANDS=   # comma-separated blocklists

# LLM Providers — configure at least one
# For local models via Ollama, no API key needed
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (optional — for local models)
# OLLAMA_BASE_URL=http://localhost:11434

# SerpAPI (optional, enables web_search tool)
# SERPAPI_KEY=your-serpapi-key

# Frontend URL for CORS (defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000
