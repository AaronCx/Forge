#!/usr/bin/env python3
"""steer — macOS GUI automation CLI for AgentForge.

Implements all 12 Steer commands using native macOS tools:
  CoreGraphics (screenshot), cliclick, osascript, pbcopy/pbpaste, and Vision OCR.
  Uses CoreGraphics directly for screenshots — works over SSH unlike screencapture.

Usage:
  steer see [--app APP] [--output PATH] [--region REGION]
  steer ocr [--app APP] [--store]
  steer click X Y | steer click --text TEXT
  steer type TEXT [--app APP]
  steer hotkey KEYS
  steer scroll DIRECTION AMOUNT [--app APP]
  steer drag START_X START_Y END_X END_Y
  steer focus APP
  steer find SEARCH_TEXT
  steer wait SEARCH_TEXT [--timeout N]
  steer clipboard read|write [TEXT]
  steer apps
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
import tempfile
import time
import uuid

import ctypes
import ctypes.util

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
OCR_HELPER = os.path.join(SCRIPT_DIR, "ocr-helper")

# ─── CoreGraphics screenshot (works over SSH) ────────────────────────────────

def _cg_screenshot(output_path: str) -> bool:
    """Capture the main display to a PNG file using CoreGraphics directly.
    Works over SSH — unlike screencapture which requires a console session."""
    try:
        cg = ctypes.cdll.LoadLibrary(ctypes.util.find_library("CoreGraphics"))
        imageio = ctypes.cdll.LoadLibrary(ctypes.util.find_library("ImageIO"))
        cf = ctypes.cdll.LoadLibrary(ctypes.util.find_library("CoreFoundation"))

        cg.CGMainDisplayID.restype = ctypes.c_uint32
        cg.CGDisplayCreateImage.restype = ctypes.c_void_p
        cg.CGDisplayCreateImage.argtypes = [ctypes.c_uint32]

        display_id = cg.CGMainDisplayID()
        image_ref = cg.CGDisplayCreateImage(display_id)
        if not image_ref:
            return False

        cf.CFStringCreateWithCString.restype = ctypes.c_void_p
        cf.CFStringCreateWithCString.argtypes = [ctypes.c_void_p, ctypes.c_char_p, ctypes.c_uint32]
        cf.CFURLCreateWithFileSystemPath.restype = ctypes.c_void_p
        cf.CFURLCreateWithFileSystemPath.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_int, ctypes.c_bool]

        path_str = cf.CFStringCreateWithCString(None, output_path.encode(), 0x08000100)
        url = cf.CFURLCreateWithFileSystemPath(None, path_str, 0, False)
        type_str = cf.CFStringCreateWithCString(None, b"public.png", 0x08000100)

        imageio.CGImageDestinationCreateWithURL.restype = ctypes.c_void_p
        imageio.CGImageDestinationCreateWithURL.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_size_t, ctypes.c_void_p]
        dest = imageio.CGImageDestinationCreateWithURL(url, type_str, 1, None)
        if not dest:
            return False

        imageio.CGImageDestinationAddImage.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p]
        imageio.CGImageDestinationAddImage(dest, image_ref, None)

        imageio.CGImageDestinationFinalize.restype = ctypes.c_bool
        imageio.CGImageDestinationFinalize.argtypes = [ctypes.c_void_p]
        return imageio.CGImageDestinationFinalize(dest)
    except Exception:
        return False


def take_screenshot(output_path: str) -> None:
    """Take a screenshot, trying CoreGraphics first, falling back to screencapture."""
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    if _cg_screenshot(output_path):
        return
    # Fallback to screencapture (works from console session)
    run(["screencapture", "-x", output_path])


def run(cmd: list[str], timeout: int = 30, input_data: bytes | None = None) -> str:
    """Run a shell command and return stdout."""
    result = subprocess.run(
        cmd,
        capture_output=True,
        timeout=timeout,
        input=input_data,
    )
    if result.returncode != 0:
        err = result.stderr.decode("utf-8", errors="replace").strip()
        raise RuntimeError(f"Command failed ({result.returncode}): {' '.join(cmd)}: {err}")
    return result.stdout.decode("utf-8", errors="replace").strip()


def output_json(data: dict) -> None:
    """Print JSON result to stdout."""
    print(json.dumps(data))


# ─── steer see ───────────────────────────────────────────────────────────────

def cmd_see(args: list[str]) -> None:
    output_path = None
    target = "screen"
    i = 0
    while i < len(args):
        if args[i] == "--output" and i + 1 < len(args):
            output_path = args[i + 1]
            i += 2
        elif args[i] == "--app" and i + 1 < len(args):
            target = args[i + 1]
            i += 2
        elif args[i] == "--region":
            i += 2  # skip region for now
        else:
            i += 1

    if not output_path:
        output_path = os.path.join(tempfile.gettempdir(), f"steer_{uuid.uuid4().hex[:8]}.png")

    os.makedirs(os.path.dirname(output_path), exist_ok=True)

    if target != "screen":
        try:
            run(["osascript", "-e", f'tell application "{target}" to activate'])
            time.sleep(0.3)
        except RuntimeError:
            pass
    take_screenshot(output_path)

    output_json({"success": True, "path": output_path})


# ─── steer ocr ───────────────────────────────────────────────────────────────

def cmd_ocr(args: list[str]) -> None:
    target = "screen"
    store = False
    i = 0
    while i < len(args):
        if args[i] == "--app" and i + 1 < len(args):
            target = args[i + 1]
            i += 2
        elif args[i] == "--store":
            store = True
            i += 1
        else:
            i += 1

    # Take screenshot first
    tmp = os.path.join(tempfile.gettempdir(), f"steer_ocr_{uuid.uuid4().hex[:8]}.png")
    if target == "screen":
        take_screenshot(tmp)
    else:
        try:
            run(["osascript", "-e", f'tell application "{target}" to activate'])
            time.sleep(0.3)
        except RuntimeError:
            pass
        take_screenshot(tmp)

    if not os.path.exists(OCR_HELPER):
        print(json.dumps({"error": "ocr-helper binary not found"}), file=sys.stderr)
        sys.exit(1)

    if store:
        raw = run([OCR_HELPER, tmp, "--json"])
        try:
            elements = json.loads(raw)
        except json.JSONDecodeError:
            elements = []
        output_json(elements)
    else:
        text = run([OCR_HELPER, tmp])
        lines = [line for line in text.split("\n") if line.strip()]
        output_json(lines)

    os.unlink(tmp)


# ─── steer click ─────────────────────────────────────────────────────────────

def cmd_click(args: list[str]) -> None:
    x, y = None, None
    element_text = None
    i = 0
    while i < len(args):
        if args[i] == "--text" and i + 1 < len(args):
            element_text = args[i + 1]
            i += 2
        elif x is None:
            x = int(args[i])
            i += 1
        elif y is None:
            y = int(args[i])
            i += 1
        else:
            i += 1

    if element_text:
        # OCR to find element, then click its center
        tmp = os.path.join(tempfile.gettempdir(), f"steer_find_{uuid.uuid4().hex[:8]}.png")
        take_screenshot(tmp)
        raw = run([OCR_HELPER, tmp, "--json"])
        elements = json.loads(raw) if raw else []
        os.unlink(tmp)

        for el in elements:
            if element_text.lower() in el.get("text", "").lower():
                x = el["x"] + el["width"] // 2
                y = el["y"] + el["height"] // 2
                break
        else:
            output_json({"success": False, "error": f"Element '{element_text}' not found"})
            sys.exit(1)

    if x is not None and y is not None:
        run(["cliclick", f"c:{x},{y}"])
        output_json({"success": True, "x": x, "y": y})
    else:
        output_json({"success": False, "error": "No coordinates or text provided"})
        sys.exit(1)


# ─── steer type ──────────────────────────────────────────────────────────────

def cmd_type(args: list[str]) -> None:
    target = ""
    text_parts = []
    i = 0
    while i < len(args):
        if args[i] == "--app" and i + 1 < len(args):
            target = args[i + 1]
            i += 2
        else:
            text_parts.append(args[i])
            i += 1
    text = " ".join(text_parts)

    if target:
        try:
            run(["osascript", "-e", f'tell application "{target}" to activate'])
            time.sleep(0.2)
        except RuntimeError:
            pass

    # Use cliclick for typing — it handles special chars better
    run(["cliclick", f"t:{text}"])
    output_json({"success": True})


# ─── steer hotkey ────────────────────────────────────────────────────────────

def cmd_hotkey(args: list[str]) -> None:
    if not args:
        output_json({"success": False, "error": "No keys specified"})
        sys.exit(1)

    keys = args[0]
    parts = keys.lower().split("+")
    modifiers = parts[:-1]
    key = parts[-1] if parts else ""

    # Use cliclick kd/ku (key-down/key-up) for modifiers + kp for the key
    # cliclick modifier names: cmd, ctrl, alt, shift, fn
    modifier_map = {
        "cmd": "cmd", "command": "cmd",
        "ctrl": "ctrl", "control": "ctrl",
        "alt": "alt", "option": "alt",
        "shift": "shift", "fn": "fn",
    }

    # Special key names for cliclick kp:
    special_keys = {
        "return": "return", "enter": "return", "tab": "tab",
        "delete": "delete", "backspace": "delete",
        "escape": "esc", "esc": "esc",
        "space": "space",
        "up": "arrow-up", "down": "arrow-down",
        "left": "arrow-left", "right": "arrow-right",
        "f1": "f1", "f2": "f2", "f3": "f3", "f4": "f4",
        "f5": "f5", "f6": "f6", "f7": "f7", "f8": "f8",
    }

    cliclick_cmds = []
    # Press modifiers down
    for m in modifiers:
        mod = modifier_map.get(m, m)
        cliclick_cmds.append(f"kd:{mod}")

    # Press the key — kp: only works for special keys, use t: for regular chars
    if key in special_keys:
        cliclick_cmds.append(f"kp:{special_keys[key]}")
    else:
        # t: types the character (works with held modifiers)
        cliclick_cmds.append(f"t:{key}")

    # Release modifiers up (reverse order)
    for m in reversed(modifiers):
        mod = modifier_map.get(m, m)
        cliclick_cmds.append(f"ku:{mod}")

    run(["cliclick"] + cliclick_cmds)
    output_json({"success": True})


# ─── steer scroll ────────────────────────────────────────────────────────────

def cmd_scroll(args: list[str]) -> None:
    direction = args[0] if args else "down"
    amount = int(args[1]) if len(args) > 1 else 3
    target = ""

    i = 2
    while i < len(args):
        if args[i] == "--app" and i + 1 < len(args):
            target = args[i + 1]
            i += 2
        else:
            i += 1

    if target:
        try:
            run(["osascript", "-e", f'tell application "{target}" to activate'])
            time.sleep(0.2)
        except RuntimeError:
            pass

    # Use cliclick for arrow key presses to simulate scrolling
    key = "arrow-down" if direction == "down" else "arrow-up"
    cliclick_cmds = [f"kp:{key}" for _ in range(amount)]
    run(["cliclick"] + cliclick_cmds)

    output_json({"success": True})


# ─── steer drag ──────────────────────────────────────────────────────────────

def cmd_drag(args: list[str]) -> None:
    if len(args) < 4:
        output_json({"success": False, "error": "drag requires start_x start_y end_x end_y"})
        sys.exit(1)

    sx, sy, ex, ey = int(args[0]), int(args[1]), int(args[2]), int(args[3])
    run(["cliclick", f"dd:{sx},{sy}", f"du:{ex},{ey}"])
    output_json({"success": True})


# ─── steer focus ─────────────────────────────────────────────────────────────

def cmd_focus(args: list[str]) -> None:
    if not args:
        output_json({"success": False, "error": "No app name specified"})
        sys.exit(1)

    app = " ".join(args)
    run(["osascript", "-e", f'tell application "{app}" to activate'])
    time.sleep(0.3)
    output_json({"success": True})


# ─── steer find ──────────────────────────────────────────────────────────────

def cmd_find(args: list[str]) -> None:
    if not args:
        output_json({"success": False, "error": "No search text specified"})
        sys.exit(1)

    search_text = " ".join(args)
    tmp = os.path.join(tempfile.gettempdir(), f"steer_find_{uuid.uuid4().hex[:8]}.png")
    take_screenshot(tmp)
    raw = run([OCR_HELPER, tmp, "--json"])
    elements = json.loads(raw) if raw else []
    os.unlink(tmp)

    for el in elements:
        if search_text.lower() in el.get("text", "").lower():
            cx = el["x"] + el["width"] // 2
            cy = el["y"] + el["height"] // 2
            output_json({"x": cx, "y": cy})
            return

    output_json({"success": False, "error": f"'{search_text}' not found"})
    sys.exit(1)


# ─── steer wait ──────────────────────────────────────────────────────────────

def cmd_wait(args: list[str]) -> None:
    search_text = ""
    timeout_sec = 10
    positional = []

    i = 0
    while i < len(args):
        if args[i] == "--timeout" and i + 1 < len(args):
            timeout_sec = int(args[i + 1])
            i += 2
        else:
            positional.append(args[i])
            i += 1

    search_text = " ".join(positional)
    if not search_text:
        output_json({"success": False, "error": "No search text"})
        sys.exit(1)

    elapsed = 0
    while elapsed < timeout_sec:
        tmp = os.path.join(tempfile.gettempdir(), f"steer_wait_{uuid.uuid4().hex[:8]}.png")
        try:
            take_screenshot(tmp)
            raw = run([OCR_HELPER, tmp, "--json"])
            elements = json.loads(raw) if raw else []
            for el in elements:
                if search_text.lower() in el.get("text", "").lower():
                    output_json({"success": True, "found_after": elapsed})
                    return
        finally:
            if os.path.exists(tmp):
                os.unlink(tmp)

        time.sleep(1)
        elapsed += 1

    output_json({"success": False, "error": "Timed out"})
    sys.exit(1)


# ─── steer clipboard ────────────────────────────────────────────────────────

def cmd_clipboard(args: list[str]) -> None:
    action = args[0] if args else "read"

    if action == "write":
        text = " ".join(args[1:]) if len(args) > 1 else ""
        run(["pbcopy"], input_data=text.encode("utf-8"))
        output_json({"success": True, "clipboard": text})
    else:
        content = run(["pbpaste"])
        output_json(content)


# ─── steer apps ──────────────────────────────────────────────────────────────

def cmd_apps(args: list[str]) -> None:
    # Try osascript with a short timeout first, fall back to ps
    try:
        script = (
            'tell application "System Events" to get name of every application process '
            'whose background only is false'
        )
        result = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True, timeout=5,
        )
        if result.returncode == 0:
            output = result.stdout.decode().strip()
            app_names = [a.strip() for a in output.split(",") if a.strip()]
            apps = [{"name": n} for n in app_names]
            output_json(apps)
            return
    except (subprocess.TimeoutExpired, Exception):
        pass

    # Fallback: use ps to list GUI apps (those in /Applications or with .app)
    output = run(["ps", "-eo", "comm"])
    seen = set()
    apps = []
    for line in output.split("\n"):
        line = line.strip()
        if ".app/" in line:
            # Extract app name from path like /Applications/Foo.app/Contents/MacOS/Foo
            parts = line.split(".app/")
            app_path = parts[0] + ".app"
            name = os.path.basename(app_path).replace(".app", "")
            if name not in seen:
                seen.add(name)
                apps.append({"name": name})
    output_json(apps)


# ─── steer record ────────────────────────────────────────────────────────────

def cmd_record(args: list[str]) -> None:
    """Record the screen using CoreGraphics frame capture piped to ffmpeg.
    Works over SSH — does not require AVFoundation or screencapture.

    Usage: steer record --output FILE [--duration N] [--fps N] [--quality low|medium|high]
           steer record --stop PID
    """
    output_path = None
    duration = 0  # 0 = until stopped
    fps = 15
    quality = "medium"
    stop_pid = None
    i = 0

    while i < len(args):
        if args[i] == "--output" and i + 1 < len(args):
            output_path = args[i + 1]
            i += 2
        elif args[i] == "--duration" and i + 1 < len(args):
            duration = int(args[i + 1])
            i += 2
        elif args[i] == "--fps" and i + 1 < len(args):
            fps = int(args[i + 1])
            i += 2
        elif args[i] == "--quality" and i + 1 < len(args):
            quality = args[i + 1]
            i += 2
        elif args[i] == "--stop" and i + 1 < len(args):
            stop_pid = int(args[i + 1])
            i += 2
        else:
            i += 1

    if stop_pid:
        import signal
        try:
            os.kill(stop_pid, signal.SIGTERM)
            output_json({"success": True, "stopped_pid": stop_pid})
        except ProcessLookupError:
            output_json({"success": False, "error": f"Process {stop_pid} not found"})
            sys.exit(1)
        return

    if not output_path:
        output_path = os.path.join(tempfile.gettempdir(), f"steer_record_{uuid.uuid4().hex[:8]}.mp4")

    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)

    bitrate_map = {"low": "2M", "medium": "5M", "high": "10M"}
    bitrate = bitrate_map.get(quality, "5M")

    # Set up CoreGraphics
    cg = ctypes.cdll.LoadLibrary(ctypes.util.find_library("CoreGraphics"))
    cf_lib = ctypes.cdll.LoadLibrary(ctypes.util.find_library("CoreFoundation"))

    cg.CGMainDisplayID.restype = ctypes.c_uint32
    cg.CGDisplayCreateImage.restype = ctypes.c_void_p
    cg.CGDisplayCreateImage.argtypes = [ctypes.c_uint32]
    cg.CGImageGetWidth.restype = ctypes.c_size_t
    cg.CGImageGetWidth.argtypes = [ctypes.c_void_p]
    cg.CGImageGetHeight.restype = ctypes.c_size_t
    cg.CGImageGetHeight.argtypes = [ctypes.c_void_p]
    cg.CGImageGetBytesPerRow.restype = ctypes.c_size_t
    cg.CGImageGetBytesPerRow.argtypes = [ctypes.c_void_p]
    cg.CGImageGetDataProvider.restype = ctypes.c_void_p
    cg.CGImageGetDataProvider.argtypes = [ctypes.c_void_p]
    cg.CGDataProviderCopyData.restype = ctypes.c_void_p
    cg.CGDataProviderCopyData.argtypes = [ctypes.c_void_p]

    cf_lib.CFDataGetLength.restype = ctypes.c_long
    cf_lib.CFDataGetLength.argtypes = [ctypes.c_void_p]
    cf_lib.CFDataGetBytePtr.restype = ctypes.c_void_p
    cf_lib.CFDataGetBytePtr.argtypes = [ctypes.c_void_p]
    cf_lib.CFRelease.argtypes = [ctypes.c_void_p]

    display_id = cg.CGMainDisplayID()
    img = cg.CGDisplayCreateImage(display_id)
    if not img:
        output_json({"success": False, "error": "Cannot access display"})
        sys.exit(1)

    w = cg.CGImageGetWidth(img)
    h = cg.CGImageGetHeight(img)

    ffmpeg_cmd = [
        "ffmpeg", "-y",
        "-f", "rawvideo",
        "-pixel_format", "bgra",
        "-video_size", f"{w}x{h}",
        "-framerate", str(fps),
        "-i", "pipe:0",
        "-c:v", "libx264",
        "-preset", "ultrafast",
        "-pix_fmt", "yuv420p",
        "-b:v", bitrate,
    ]
    if duration > 0:
        ffmpeg_cmd.extend(["-t", str(duration)])
    ffmpeg_cmd.append(output_path)

    proc = subprocess.Popen(
        ffmpeg_cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )

    # Write our PID so callers can stop us
    pid_file = output_path + ".pid"
    with open(pid_file, "w") as f:
        f.write(str(os.getpid()))

    import signal
    recording = True

    def handle_stop(signum, frame):
        nonlocal recording
        recording = False

    signal.signal(signal.SIGTERM, handle_stop)
    signal.signal(signal.SIGINT, handle_stop)

    frame_interval = 1.0 / fps
    frame_count = 0
    max_frames = fps * duration if duration > 0 else float("inf")

    try:
        while recording and frame_count < max_frames:
            t0 = time.monotonic()
            img = cg.CGDisplayCreateImage(display_id)
            if not img:
                continue

            bpr = cg.CGImageGetBytesPerRow(img)
            provider = cg.CGImageGetDataProvider(img)
            data = cg.CGDataProviderCopyData(provider)
            length = cf_lib.CFDataGetLength(data)
            ptr = cf_lib.CFDataGetBytePtr(data)
            raw = ctypes.string_at(ptr, length)

            if bpr != w * 4:
                frame = b""
                for row in range(h):
                    frame += raw[row * bpr : row * bpr + w * 4]
                raw = frame

            proc.stdin.write(raw)
            cf_lib.CFRelease(data)
            frame_count += 1

            elapsed = time.monotonic() - t0
            sleep_time = frame_interval - elapsed
            if sleep_time > 0:
                time.sleep(sleep_time)
    except BrokenPipeError:
        pass

    proc.stdin.close()
    proc.wait(timeout=15)

    # Clean up pid file
    if os.path.exists(pid_file):
        os.unlink(pid_file)

    file_size = os.path.getsize(output_path) if os.path.exists(output_path) else 0
    output_json({
        "success": proc.returncode == 0,
        "path": output_path,
        "frames": frame_count,
        "duration_seconds": frame_count / fps,
        "resolution": f"{w}x{h}",
        "fps": fps,
        "size_bytes": file_size,
    })


# ─── Main dispatch ───────────────────────────────────────────────────────────

COMMANDS = {
    "see": cmd_see,
    "ocr": cmd_ocr,
    "click": cmd_click,
    "type": cmd_type,
    "hotkey": cmd_hotkey,
    "scroll": cmd_scroll,
    "drag": cmd_drag,
    "focus": cmd_focus,
    "find": cmd_find,
    "wait": cmd_wait,
    "clipboard": cmd_clipboard,
    "apps": cmd_apps,
    "record": cmd_record,
}


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: steer <command> [args...]", file=sys.stderr)
        print(f"Commands: {', '.join(COMMANDS.keys())}", file=sys.stderr)
        sys.exit(1)

    command = sys.argv[1]
    if command == "--version":
        print("steer 1.0.0 (macOS native)")
        sys.exit(0)

    if command == "--help":
        print(__doc__)
        sys.exit(0)

    handler = COMMANDS.get(command)
    if not handler:
        print(f"Unknown command: {command}", file=sys.stderr)
        sys.exit(1)

    try:
        handler(sys.argv[2:])
    except Exception as e:
        output_json({"success": False, "error": str(e)})
        sys.exit(1)


if __name__ == "__main__":
    main()
